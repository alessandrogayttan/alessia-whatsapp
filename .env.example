# Copia este archivo como .env y completa los valores.
# Nunca subas .env ni JSON de service account a GitHub.

FLASK_ENV=development
PORT=5000

# WhatsApp / Meta
TOKEN_WHATSAPP=
ID_TELEFONO=
META_APP_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
META_DOMAIN_VERIFICATION_CODE=
WEBHOOK_CALLBACK_URL=https://alessia-whatsapp-jbems.ondigitalocean.app/webhook

# Producción: pegar JSON completo (preferido). No subir el archivo .json al repo.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Solo local; ruta fuera del repo o en data/ (gitignored)
GOOGLE_SERVICE_ACCOUNT_FILE=data/google-service-account.json
ID_HOJA_CALCULO=
DATABASE_PATH=data/alessia.db

GEMINI_API_KEY=
API_KEY_MAPS=

ENABLE_SCHEDULER=1
